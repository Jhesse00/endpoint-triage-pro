{
  "name": "endpoint-triage-pro",
  "version": "0.1.0",
  "private": true,
  "description": "Windows endpoint triage desktop dashboard for help desk technicians.",
  "main": "dist-electron/main.js",
  "author": "Johanne Hesse",
  "scripts": {
    "dev": "vite",
    "electron:build": "tsc -p tsconfig.electron.json",
    "electron:dev": "concurrently -k \"vite\" \"tsc -p tsconfig.electron.json --watch --preserveWatchOutput\" \"wait-on http://localhost:5173 dist-electron/main.js && cross-env VITE_DEV_SERVER_URL=http://localhost:5173 electron .\"",
    "build": "vite build",
    "build:all": "npm run build && npm run electron:build",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.electron.json --noEmit",
    "preview": "vite preview",
    "dist": "npm run build:all && electron-builder",
    "dist:win": "npm run build:all && electron-builder --win"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2",
    "vite": "^6.0.7",
    "wait-on": "^8.0.1"
  },
  "build": {
    "appId": "com.johannehesse.endpointtriagepro",
    "productName": "Endpoint Triage Pro",
    "executableName": "EndpointTriagePro",
    "copyright": "Copyright © 2026 Johanne Hesse",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "scripts",
        "to": "scripts",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "signtoolOptions": {
        "publisherName": "Johanne Hesse"
      },
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
